# ── Default: normalize line endings to LF in the repo ────────────────────────
* text=auto eol=lf

# ── Python source ─────────────────────────────────────────────────────────────
*.py text eol=lf

# ── Markdown and text ─────────────────────────────────────────────────────────
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf

# ── Config / data files ───────────────────────────────────────────────────────
.gitignore text eol=lf
.gitattributes text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# ── Binary — do not diff or modify line endings ───────────────────────────────
*.png binary
*.jpg binary
*.jpeg binary
*.bmp binary
*.tiff binary
*.webp binary
*.joblib binary
*.pkl binary
*.npy binary
*.npz binary

# ── Linguist: mark generated/data files so they don't pollute GitHub stats ───
results/tuning/**/*.png linguist-generated=true
results/examples/*.png linguist-documentation=true